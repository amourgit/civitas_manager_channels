{
  "name": "@civitas/whatsapp",
  "version": "2026.4.4",
  "description": "CIVITAS WhatsApp channel plugin",
  "type": "module",
  "dependencies": {
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "jimp": "^1.6.0"
  },
  "devDependencies": {
    "civitas_manager_channels": "workspace:*"
  },
  "civitas": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "whatsapp",
      "label": "WhatsApp",
      "selectionLabel": "WhatsApp (QR link)",
      "detailLabel": "WhatsApp Web",
      "docsPath": "/channels/whatsapp",
      "docsLabel": "whatsapp",
      "blurb": "works with your own number; recommend a separate phone + eSIM.",
      "systemImage": "message"
    },
    "install": {
      "npmSpec": "@civitas/whatsapp",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.4"
    },
    "compat": {
      "pluginApi": ">=2026.4.4"
    },
    "build": {
      "civitasVersion": "2026.4.4"
    },
    "release": {
      "publishToChannelHub": true,
      "publishToNpm": true
    }
  }
}
