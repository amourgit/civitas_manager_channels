{
  "name": "@civitas/memory-lancedb",
  "version": "2026.4.4",
  "description": "OpenClaw LanceDB-backed long-term memory plugin with auto-recall/capture",
  "type": "module",
  "dependencies": {
    "@lancedb/lancedb": "^0.27.2",
    "@sinclair/typebox": "0.34.49",
    "openai": "^6.33.0"
  },
  "civitas": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@civitas/memory-lancedb",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.4"
    },
    "compat": {
      "pluginApi": ">=2026.4.4"
    },
    "build": {
      "civitasVersion": "2026.4.4"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
