{
  "name": "@civitas/nextcloud-talk",
  "version": "2026.4.4",
  "description": "CIVITAS Nextcloud Talk channel plugin",
  "type": "module",
  "devDependencies": {
    "civitas": "workspace:*"
  },
  "peerDependencies": {
    "civitas": ">=2026.4.4"
  },
  "peerDependenciesMeta": {
    "civitas": {
      "optional": true
    }
  },
  "civitas": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "nextcloud-talk",
      "label": "Nextcloud Talk",
      "selectionLabel": "Nextcloud Talk (self-hosted)",
      "docsPath": "/channels/nextcloud-talk",
      "docsLabel": "nextcloud-talk",
      "blurb": "Self-hosted chat via Nextcloud Talk webhook bots.",
      "aliases": [
        "nc-talk",
        "nc"
      ],
      "order": 65,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@civitas/nextcloud-talk",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.4"
    },
    "compat": {
      "pluginApi": ">=2026.4.4"
    },
    "build": {
      "civitasVersion": "2026.4.4"
    },
    "release": {
      "publishToChannelHub": true,
      "publishToNpm": true
    }
  }
}
