{
  "name": "@civitas/nostr",
  "version": "2026.4.4",
  "description": "OpenClaw Nostr channel plugin for NIP-04 encrypted DMs",
  "type": "module",
  "dependencies": {
    "nostr-tools": "^2.23.3"
  },
  "devDependencies": {
    "civitas": "workspace:*"
  },
  "peerDependencies": {
    "civitas": ">=2026.4.4"
  },
  "peerDependenciesMeta": {
    "civitas": {
      "optional": true
    }
  },
  "civitas": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "nostr",
      "label": "Nostr",
      "selectionLabel": "Nostr (NIP-04 DMs)",
      "docsPath": "/channels/nostr",
      "docsLabel": "nostr",
      "blurb": "Decentralized protocol; encrypted DMs via NIP-04.",
      "order": 55,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@civitas/nostr",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.4"
    },
    "compat": {
      "pluginApi": ">=2026.4.4"
    },
    "build": {
      "civitasVersion": "2026.4.4"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
